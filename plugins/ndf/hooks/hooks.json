{
  "description": "NDF Plugin hooks: transcript retention guard and Slack notifications",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "description": "Ensure ~/.claude/settings.json cleanupPeriodDays >= 90 (guarded by 7-day timestamp flag)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/ensure-retention.sh",
            "description": "NDF: ensure transcript retention >= 90 days",
            "continueOnError": true,
            "suppressOutput": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/slack-notify.js session_end",
            "description": "Send Slack notification when Claude Code exits"
          }
        ]
      }
    ]
  }
}
