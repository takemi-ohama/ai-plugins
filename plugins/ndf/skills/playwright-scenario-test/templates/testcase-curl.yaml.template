# curl タイプ testcase テンプレート (疎通検査専用、Playwright 不使用)
# 大量 URL の HTTP ステータス + body 文字列を高速にチェックする用途。
# 認証要否は basic_auth: skip / required / optional で指定。

id: TC-CURL-{role}-{slug}
title: 疎通検査 ({role}) — エンドポイント別 HTTP ステータス確認
phase: 0
type: curl
role: {role}                           # 任意 (フィルタ用)
priority: medium
page_role: lp                          # 任意 (フィルタ用)
tags: [curl, smoke]
description: |
  対象環境の主要エンドポイントが想定 HTTP コードで返ることのみ確認する。
  Playwright を起動しないため数十 URL を並列に叩いても軽量。

checks:
  - id: TC-CURL-{role}-001
    name: トップページ
    path: /
    basic_auth: optional
    expect_status_in: [200]
    body_must_contain: ["<html"]
  - id: TC-CURL-{role}-002
    name: ヘルスチェック
    path: /health
    basic_auth: skip
    expect_status_in: [200, 204]
    body_must_contain: []
  - id: TC-CURL-{role}-003
    name: ログイン画面 (匿名)
    path: /login
    basic_auth: skip
    expect_status_in: [200]
    body_must_contain: ["ログイン"]
  - id: TC-CURL-{role}-004
    name: 静的ファイル (CSS)
    path: /static/css/main.css
    basic_auth: skip
    expect_status_in: [200]
    body_must_contain: []
  - id: TC-CURL-{role}-005
    name: 404 ページが意図通り返るか
    path: /this-path-does-not-exist
    basic_auth: skip
    expect_status_in: [404]
    body_must_contain: ["Not Found"]
