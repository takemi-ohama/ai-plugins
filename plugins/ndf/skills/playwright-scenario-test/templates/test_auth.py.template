"""認証 (auth) 系テストの雛形 (v0.3.0+)。

ログインフロー単体の検証。NDF が提供する ``ndf_role_<id>`` fixture で
``page`` に storage_state を inject 済みなので、test 関数は遷移先の URL や
画面要素のみ検証すればよい。

実行:
    uv run pytest tests/test_auth.py --ndf-config=./scenario.config.yaml
"""

from __future__ import annotations

import pytest
from playwright.sync_api import Page, expect


@pytest.mark.page_role("auth")
@pytest.mark.role("admin")
@pytest.mark.phase(1)
def test_admin_login_redirects_to_dashboard(
    page: Page, ndf_role_admin, ndf_config, ndf_evidence
):
    """admin login 後、/admin/dashboard が表示されること。"""
    page.goto(f"{ndf_config.base_url}/admin/dashboard", wait_until="domcontentloaded")
    expect(page).to_have_url(lambda u: "/admin/dashboard" in u)
    expect(page.get_by_role("heading", name="ダッシュボード")).to_be_visible()


@pytest.mark.page_role("auth")
def test_logout_clears_session(page: Page, ndf_role_admin, ndf_config):
    """logout 後にログインページへ遷移し、保護リソースに直接アクセスすると
    再ログインを要求されること。"""
    page.goto(f"{ndf_config.base_url}/logout", wait_until="domcontentloaded")
    page.goto(f"{ndf_config.base_url}/admin/dashboard", wait_until="domcontentloaded")
    expect(page).to_have_url(lambda u: "/login" in u)
