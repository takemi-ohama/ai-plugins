# 汎用 Playwright testcase テンプレート (locator-first / web-first assertion)
# v0.3.0 で導入された step kind を組み合わせる。`{role}`/`{slug}` は手動置換。
#
# Step kind 一覧 (詳細は docs/04-playwright-mapping.md):
#   goto                : ページ遷移 (path 必須、expect_status 任意)
#   click / hover       : 要素操作 (locator 必須)
#   fill / select       : 入力 / セレクト (locator + value 必須)
#   check / uncheck     : チェックボックス操作 (locator 必須)
#   press               : キー押下 (locator + value=Enter/Tab/...)
#   extract             : テキストを変数に保存 (locator + var)
#   wait_for / wait_ms  : 明示待機 (auto-waiting で十分なら不要)
#   expect_visible      : 表示確認 (locator)
#   expect_hidden       : 非表示確認 (locator)
#   expect_text         : テキスト含有 (locator + text)
#   expect_no_text      : テキスト非含有 (locator + text) — フレームワーク fatal 検知などに
#   expect_url          : URL 部分一致 (contains)
#   expect_count        : 要素数 (locator + count)
#   expect_aria_snapshot: ARIA snapshot 一致 (locator + text=snapshot YAML)
#
# Locator スキーマ (優先順):
#   {role: button, name: "保存"}     → page.get_by_role(...)
#   {label: "メールアドレス"}         → page.get_by_label(...)
#   {placeholder: "Search"}           → page.get_by_placeholder(...)
#   {text: "ログアウト", exact: true} → page.get_by_text(...)
#   {alt: "ロゴ"}                     → page.get_by_alt_text(...)
#   {title: "ヘルプ"}                 → page.get_by_title(...)
#   {testid: "submit-btn"}            → page.get_by_test_id(...)
#   {css: ".alert"}                   → page.locator(...)         # 最後の手段
#   {xpath: "//main"}                 → page.locator("xpath=...")  # 最後の手段
#
# 変数展開: `{var_name}` 形式の placeholder を path / value / text 内に書ける。
#         extract step で保存した値を後続 step が参照可能。

id: TC-{role}-{slug}
title: 汎用シナリオ ({role} / {slug})
phase: 10
type: playwright
role: {role}
priority: medium
page_role: list                    # docs/02-page-roles.md 参照
tags: [{role}, scenario]
description: |
  概要を記述。docs/checklists/checklist-{page_role}.md を必ず参照すること。

post_login:
  url_must_not_contain: []         # ログイン後 URL に含まれてはいけない部分文字列

steps:
  - kind: goto
    name: トップページ表示
    path: /
    expect_status: 200
  - kind: expect_visible
    name: ヘッダロゴ表示確認
    locator: { role: img, name: ロゴ }
  - kind: click
    name: メニュー → 一覧
    locator: { role: link, name: 一覧 }
  - kind: expect_url
    name: 一覧画面遷移確認
    contains: /items
  - kind: expect_no_text
    name: フレームワーク fatal が出ていないこと
    locator: { css: body }
    text: "Fatal error"
