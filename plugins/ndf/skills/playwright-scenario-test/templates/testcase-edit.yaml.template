id: TC-EDT-{role}-{slug}
title: 編集ページ ({role}) — BVA + validation + CSRF + dirty 検知
phase: 30
type: playwright
role: {role}
priority: high
page_role: edit
tags: [edit, validation, scenario]
description: |
  docs/checklists/checklist-edit.md (14 項目) を必ず参照。
  必須技法: BVA, EP, Decision Table, State Transition (clean/dirty/saving).
  Triggers: '編集', 'edit', 'validation', 'バリデーション', 'CSRF', 'dirty'

  項目別の検査計画:
    - ED1 プリフィル:           step 1
    - ED2 境界値 (BVA):         step 2〜5 (parametrize で展開)
    - ED4 必須未入力:           step 6
    - ED5 client/server 一致:    step 7
    - ED8 CSRF token 削除:      step 8
    - ED9 dirty 検知:           step 9 (別ページへ navigate)
    - ED13 no-op 保存:          step 10

post_login:
  url_must_not_contain: []

steps:
  # === ED1: プリフィル ===
  - name: "[ED1] 編集画面プリフィル"
    path: /items/${ITEM_ID}/edit

  # === ED2: BVA — 各フィールドの境界値 ===
  # 「title 長さ 1〜100 仕様」を例に min-1/min/max/max+1 を試す
  # NOTE: scenario_test ランナーは現状フィールド入力をサポートしないため、
  #       実際の入力テストは pytest-playwright (将来) または手動補完で実施
  - name: "[ED2] title 長さ 0 (min-1)"
    path: /items/${ITEM_ID}/edit?prefill_title=

  - name: "[ED2] title 長さ 1 (min)"
    path: /items/${ITEM_ID}/edit?prefill_title=A

  - name: "[ED2] title 長さ 100 (max)"
    path: /items/${ITEM_ID}/edit?prefill_title=AAAAAAAAAA  # 実際は 100 文字

  - name: "[ED2] title 長さ 101 (max+1)"
    path: /items/${ITEM_ID}/edit?prefill_title=BBBBBBBBBB  # 実際は 101 文字

  # === ED8: CSRF token 削除攻撃 ===
  - name: "[ED8] CSRF token なしで POST"
    path: /items/${ITEM_ID}/update
    method: POST
    data:
      title: "csrf-bypass-test"
    expect_status: 403  # token なしで 403 期待

  # === ED9: dirty 検知 (E2E 単体では困難 — 手動 or 拡張 runner) ===
  # 実装メモ: scenario_test ランナーには beforeunload 検知機構がない。
  # 別途 pytest-playwright で page.on("dialog", ...) を使うこと

# ============================================================
# 関連: docs/03-test-techniques.md § 1〜3 (EP / BVA / Decision Table)
# ============================================================
